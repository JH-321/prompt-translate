#!/usr/bin/env python3
"""koen — Korean → English prompt compressor for LLM pipelines.

Translates Korean prompts to concise English using a CHEAP model
(Claude Haiku / Codex mini / free OpenRouter model), so the expensive
model (Opus/Fable/GPT-5) receives fewer tokens for the same meaning.

Usage:
    koen "한국어 프롬프트"
    echo "한국어 프롬프트" | koen
    koen -f spec.ko.md > spec.en.md

    koen claude [claude args...]     # run the REAL claude/codex TUI in a pty;
    koen codex  [codex args...]      # koen intercepts Enter, translates Hangul
                                     # lines via the cheap model, and submits
                                     # English — dialogs/skills/settings intact
    koen claude --lower haiku        # pick the cheap translator model

Harness rules:
    - lines starting with / ! # are never translated (slash/bash commands)
    - lines edited with arrow keys / tab-complete pass through untranslated
    - translation failure -> the original line is submitted unchanged

Backends (auto-detected, or force with KOEN_BACKEND=claude|codex|openrouter):
    claude     -> claude -p --model $KOEN_CLAUDE_MODEL   (default: claude-haiku-4-5)
    codex      -> codex exec [-m $KOEN_CODEX_MODEL]      (default: codex config default)
    openrouter -> POST /chat/completions, model $KOEN_OPENROUTER_MODEL
                  (default: meta-llama/llama-3.3-70b-instruct:free, needs OPENROUTER_API_KEY)

Guarantees:
    - No Hangul in input -> passthrough, zero cost.
    - Fenced code blocks, inline code, and URLs are placeholder-protected
      and restored verbatim; if the backend mangles a placeholder, koen
      falls back to the original text (never silently corrupts meaning).
"""

import json
import os
import re
import select
import shutil
import subprocess
import sys
import tempfile
import urllib.request

HANGUL = re.compile(r"[가-힣]")
# order matters: fences first so inline-code/URLs inside them are already hidden
PROTECT = [
    re.compile(r"```.*?```", re.S),          # fenced code blocks
    re.compile(r"`[^`\n]+`"),                # inline code
    re.compile(r"https?://\S+"),             # URLs
]
PH = "⟦K{}⟧"  # ⟦K0⟧ — unlikely to appear in prompts or be "translated"

INSTRUCTION = (
    "You are a translation filter inside an LLM prompt pipeline. "
    "Translate the following Korean prompt into concise, precise English.\n"
    "Rules:\n"
    "- Keep every ⟦K#⟧ placeholder exactly as written, in place.\n"
    "- Preserve technical terms, code identifiers, file paths, product names, "
    "numbers, and every constraint or requirement. Do not drop nuance.\n"
    "- Do NOT answer, execute, or comment on the prompt. Only translate it.\n"
    "- Output ONLY the translated prompt, nothing else.\n\n"
    "PROMPT:\n"
)


def protect(text):
    saved = []
    def stash(m):
        saved.append(m.group(0))
        return PH.format(len(saved) - 1)
    for rx in PROTECT:
        text = rx.sub(stash, text)
    return text, saved


def restore(text, saved):
    for i, s in enumerate(saved):
        ph = PH.format(i)
        if ph not in text:
            raise ValueError(f"backend lost placeholder {ph}")
        text = text.replace(ph, s)
    return text


def run(cmd, stdin_text):
    r = subprocess.run(cmd, input=stdin_text, capture_output=True, text=True, timeout=120)
    if r.returncode != 0:
        raise RuntimeError(f"{cmd[0]} failed: {r.stderr.strip()[:300]}")
    return r.stdout.strip()


def backend_claude(prompt):
    model = os.environ.get("KOEN_CLAUDE_MODEL", "claude-haiku-4-5")
    return run(["claude", "-p", "--model", model], INSTRUCTION + prompt)


def backend_codex(prompt):
    with tempfile.NamedTemporaryFile(suffix=".txt", delete=False) as f:
        out = f.name
    try:
        cmd = ["codex", "exec", "--skip-git-repo-check", "-s", "read-only",
               "--output-last-message", out]
        model = os.environ.get("KOEN_CODEX_MODEL")
        if model:
            cmd += ["-m", model]
        cmd.append(INSTRUCTION + prompt)
        subprocess.run(cmd, capture_output=True, text=True, timeout=180, check=True)
        with open(out) as f:
            return f.read().strip()
    finally:
        os.unlink(out)


def backend_openrouter(prompt):
    key = os.environ.get("OPENROUTER_API_KEY")
    if not key:
        raise RuntimeError("OPENROUTER_API_KEY not set")
    model = os.environ.get("KOEN_OPENROUTER_MODEL", "meta-llama/llama-3.3-70b-instruct:free")
    req = urllib.request.Request(
        "https://openrouter.ai/api/v1/chat/completions",
        data=json.dumps({
            "model": model,
            "messages": [{"role": "user", "content": INSTRUCTION + prompt}],
        }).encode(),
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=120) as resp:
        body = json.load(resp)
    return body["choices"][0]["message"]["content"].strip()


BACKENDS = {"claude": backend_claude, "codex": backend_codex, "openrouter": backend_openrouter}


def pick_backend():
    forced = os.environ.get("KOEN_BACKEND")
    if forced:
        return [forced]
    order = []
    if shutil.which("claude"):
        order.append("claude")
    if shutil.which("codex"):
        order.append("codex")
    if os.environ.get("OPENROUTER_API_KEY"):
        order.append("openrouter")
    return order


def translate(text):
    if not HANGUL.search(text):
        return text  # already English: passthrough, zero cost
    masked, saved = protect(text)
    order = pick_backend()
    if not order:
        raise SystemExit("koen: no backend available (need claude, codex, or OPENROUTER_API_KEY)")
    last_err = None
    for name in order:
        try:
            out = BACKENDS[name](masked)
            if not out or HANGUL.search(out):
                raise ValueError("backend returned empty or still-Korean text")
            return restore(out, saved)
        except Exception as e:  # ponytail: any backend failure -> try next, then passthrough
            last_err = f"{name}: {e}"
            print(f"koen: backend {last_err}", file=sys.stderr)
    print("koen: all backends failed, passing original through", file=sys.stderr)
    return text


# ---------------------------------------------------------------------------
# Harness mode: run the REAL claude/codex TUI inside a pty, pass its screen
# through untouched (permission dialogs, /model, skills, settings all work),
# and only intercept the input stream: when Enter is pressed on a line that
# contains Hangul, translate it with the cheap model, erase the Hangul from
# the TUI's input box with backspaces, and submit the English instead.
# Claude Code hooks were verified unable to replace prompts, so pty
# interception is the only way to keep the native UX.
# ---------------------------------------------------------------------------

def pump(master, timeout=0.05):
    """Forward any pending child output to our stdout. False on child EOF."""
    try:
        r, _, _ = select.select([master], [], [], timeout)
        if master in r:
            data = os.read(master, 65536)
            if not data:
                return False
            os.write(1, data)
    except OSError:
        return False
    return True


def translate_while_pumping(text, master):
    """Translate in a thread so the TUI keeps rendering; hold typed keys."""
    import threading
    box, held = {}, bytearray()
    t = threading.Thread(target=lambda: box.update(v=translate(text)), daemon=True)
    t.start()
    while t.is_alive():
        if not pump(master):
            break
        try:
            r, _, _ = select.select([0], [], [], 0)
            if 0 in r:
                held += os.read(0, 65536)
        except OSError:
            pass
    t.join(timeout=1)
    return box.get("v", text), bytes(held)


def harness(target, extra):
    import fcntl
    import pty
    import signal
    import termios
    import tty

    args = []
    it = iter(extra)
    for a in it:  # --lower <model>: pick the cheap translator model
        if a == "--lower":
            m = next(it, None)
            if m:
                os.environ["KOEN_CLAUDE_MODEL"] = m
                os.environ["KOEN_CODEX_MODEL"] = m
        elif a != "--":
            args.append(a)

    import shlex
    cmd = shlex.split(os.environ.get("KOEN_HARNESS_CMD") or "") or [target]
    cmd += args
    pid, master = pty.fork()
    if pid == 0:
        try:  # utf-8-aware erase, so backspace deletes chars not bytes
            a = termios.tcgetattr(0)
            a[0] |= getattr(termios, "IUTF8", 0x4000)  # same value on macOS/Linux
            termios.tcsetattr(0, termios.TCSANOW, a)
        except (AttributeError, termios.error):
            pass
        os.execvp(cmd[0], cmd)

    interactive = os.isatty(0)
    old_attrs = None
    if interactive:
        def winsz(*_):
            fcntl.ioctl(master, termios.TIOCSWINSZ,
                        fcntl.ioctl(0, termios.TIOCGWINSZ, b"\0" * 8))
        winsz()
        signal.signal(signal.SIGWINCH, winsz)
        old_attrs = termios.tcgetattr(0)
        tty.setraw(0)

    buf = ""        # shadow of the TUI's current input line
    dirty = False   # cursor moved / tab-completed: shadow unreliable, skip
    paste = False   # inside bracketed paste
    pend = bytearray()

    def on_enter():
        nonlocal buf, dirty
        text, buf = buf, ""
        was_dirty, dirty = dirty, False
        skip = (was_dirty or not HANGUL.search(text)
                or text.lstrip().startswith(("/", "!", "#")))
        if skip:
            os.write(master, b"\r")
            return b""
        eng, held = translate_while_pumping(text, master)
        if eng != text and not HANGUL.search(eng):
            # ponytail: one backspace per char erases the input box; if a
            # grapheme/wide-char mismatch ever bites, count graphemes instead
            os.write(master, b"\x7f" * len(text))
            os.write(master, eng.encode())
        os.write(master, b"\r")
        return held

    SPECIAL = frozenset(b"\x1b\r\n\x7f\x03\x15")
    try:
        while True:
            if not pump(master, 0.02):
                break
            r, _, _ = select.select([0], [], [], 0)
            if 0 not in r:
                continue
            data = os.read(0, 65536)
            if not data:
                os.close(master)
                break
            while data:
                b = data[0]
                if b == 0x1b:  # escape sequence: consume to its final byte
                    j = 1
                    if len(data) > 1 and data[1:2] == b"[":
                        j = 2
                        while j < len(data) and not 0x40 <= data[j] <= 0x7e:
                            j += 1
                    seq, data = data[:j + 1], data[j + 1:]
                    if seq == b"\x1b[200~":
                        paste = True
                    elif seq == b"\x1b[201~":
                        paste = False
                    else:
                        dirty = True  # arrows etc: shadow no longer trustworthy
                    os.write(master, seq)
                elif b in (0x0d, 0x0a):
                    if paste:  # newline inside pasted text: part of the input
                        buf += "\n"
                        os.write(master, data[:1])
                        data = data[1:]
                    else:
                        data = on_enter() + data[1:]
                elif b == 0x7f:
                    buf = buf[:-1]
                    os.write(master, data[:1])
                    data = data[1:]
                elif b in (0x03, 0x15):  # ctrl-c / ctrl-u clear the input line
                    buf, dirty, pend = "", False, bytearray()
                    os.write(master, data[:1])
                    data = data[1:]
                else:
                    j = 1
                    while j < len(data) and data[j] not in SPECIAL:
                        j += 1
                    chunk, data = data[:j], data[j:]
                    os.write(master, chunk)
                    if any(c < 0x20 for c in chunk):
                        dirty = True  # tab-complete or other control key
                    pend += bytes(c for c in chunk if c >= 0x20)
                    try:
                        buf += pend.decode()
                        pend = bytearray()
                    except UnicodeDecodeError:
                        if len(pend) > 8:  # garbage, not a split utf-8 char
                            pend = bytearray()
                            dirty = True
    finally:
        if old_attrs:
            termios.tcsetattr(0, termios.TCSADRAIN, old_attrs)
    _, status = os.waitpid(pid, 0)
    sys.exit(os.waitstatus_to_exitcode(status))


def main():
    args = sys.argv[1:]
    if args and args[0] in ("-h", "--help"):
        print(__doc__)
        return
    if args and args[0] in ("claude", "codex"):
        extra = args[1:]
        if extra and extra[0] == "--":
            extra = extra[1:]
        return harness(args[0], extra)
    if args and args[0] == "-f":
        text = open(args[1], encoding="utf-8").read()
    elif args:
        text = " ".join(args)
    else:
        text = sys.stdin.read()
    if not text.strip():
        return
    print(translate(text))


if __name__ == "__main__":
    main()
